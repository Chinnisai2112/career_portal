# Mongo + auth
MONGO_URI=mongodb://127.0.0.1:27017/career_portal
JWT_SECRET=change-me
# Access token lifetime (e.g. 1d, 12h). Logout bumps user.tokenVersion so old tokens stop working.
JWT_EXPIRES_IN=1d

# Comma-separated emails that may access admin APIs/UI.
ADMIN_HOST_EMAIL=you@example.com

# Resume ATS checker - Groq free tier
GROQ_API_KEY_RESUME_CHECKER=
GROQ_RESUME_MODEL=llama-3.1-8b-instant

# Resume builder - Gemini free tier
GEMINI_API_KEY_RESUME_BUILDER=
GEMINI_RESUME_BUILDER_MODEL=gemini-2.0-flash

# Mock interview - Gemini free tier
GEMINI_API_KEY_INTERVIEW=
GEMINI_INTERVIEW_MODEL=gemini-2.0-flash

# Career guidance - Gemini free tier
GEMINI_API_KEY_CAREER=
GEMINI_CAREER_MODEL=gemini-2.0-flash

# Performance analysis - OpenRouter free model first, Groq fallback
OPENROUTER_API_KEY=
OPENROUTER_PERFORMANCE_MODEL=google/gemma-2-9b-it:free
GROQ_API_KEY_PERFORMANCE=
GROQ_PERFORMANCE_MODEL=llama-3.1-8b-instant

# Shared fallback keys if feature-specific keys are not set.
GROQ_API_KEY=
GEMINI_API_KEY=

# Optional branding for OpenRouter
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=Career Portal
