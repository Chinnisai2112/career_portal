{
  "name": "career_portal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "server": "node server.js",
    "dev": "nodemon server.js",
    "check:db": "node scripts/check-db.js",
    "client": "npm --prefix client start",
    "client:build": "npm --prefix client run build",
    "client:install": "npm --prefix client install",
    "install:all": "npm install && npm run client:install",
    "dev:full": "concurrently -n web,api -c cyan,magenta \"npm run client\" \"npm run dev\"",
    "build": "npm run client:build"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.1",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.64.0",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.14"
  }
}
